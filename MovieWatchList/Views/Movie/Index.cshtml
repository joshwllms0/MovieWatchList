@model List<MovieWatchList.Models.Movie>

@{
    ViewData["Title"] = "My Movies";
}

<div class="container mt-4">
    <h1>My Movie Watchlist</h1>

    <div class="mb-3">
        <a asp-action="Create" class="btn btn-primary">Add Movie</a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">
            No movies yet. Add your first movie!
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var movie in Model)
            {
                <div class="col-mb-6 mb-3">
                    <div class="card">
                        <div class=" card-body">
                            <h5 class="card-title">
                                @movie.Title (@movie.Year)
                                <span class="badge bg-@(movie.Watched ? "success" : "warning")">
                                    @movie.Status
                                </span>
                            </h5>

                            @if (!string.IsNullOrEmpty(movie.Description))
                            {
                                <p class="card-text">@movie.Description</p>
                            }

                            <div class="mt-2">
                                <a asp-action="ToggleWatched" asp-route-id="@movie.Id"
                                   class="btn btn-sm btn-@(movie.Watched ? "secondary" : "seccess")">
                                    @(movie.Watched ? "Mark Unwatched" : "Mark Watched")
                                </a>

                                <a asp-action="Delete" asp-route-id="@movie.Id" class="btn btn-sm btn-danger"
                                   onclick="return confirm('Delete @movie.Title?')">Delete</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="mt-3">
            <p class="text-muted">
                Total Movied: @Model.Count |
                Watched: @Model.Count(m => m.Watched) |
                To Watch: @Model.Count(m => !m.Watched)
            </p>
        </div>
    }
</div>